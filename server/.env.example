OPENAI_API_KEY=sk-remplacez-par-votre-nouvelle-cle
APP_API_KEY=changez-ce-jeton-partage
OPENAI_MODEL=gpt-4o
MAX_TOKENS=1000
RATE_LIMIT_PER_MIN=30
# Liste séparée par des virgules des origines autorisées (CORS). Vide = tous bloqués.
# Exemple : https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=
# Firebase App Check (optionnel). Renseignez votre projectId pour exiger un token
# X-Firebase-AppCheck valide en plus du token X-App-Key. Vide = désactivé.
# Nécessite de définir GOOGLE_APPLICATION_CREDENTIALS pointant vers le JSON
# du service account Firebase (rôle "Firebase App Check Admin").
FIREBASE_PROJECT_ID=
# Modération OpenAI activée par défaut. Mettre "false" pour la désactiver (déconseillé en prod).
MODERATION_ENABLED=true
# Version applicative (utilisée pour Sentry "release" et /health).
APP_VERSION=1.0.0
# Sentry (optionnel). Renseignez votre DSN pour activer le crash reporting.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
